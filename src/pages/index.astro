---
// Homepage: a static introduction to the site, plus (for enrolled visitors)
// the progress dashboard island. The island renders nothing when no course
// is enrolled, so first-time visitors only see the intro.
import Layout from '../layouts/Layout.astro';
import HomeApp from '../components/apps/HomeApp.svelte';
import { href } from '../lib/paths.js';
---

<Layout title="Home">
  <div class="page-header">
    <h1>Learn Anywhere</h1>
    <a class="btn btn-primary" href={href('/courses/')}>Browse courses →</a>
  </div>

  <section class="intro">
    <p class="tagline">Courses that live in your browser.</p>
    <p class="muted">
      Learn Anywhere is a lightweight way to take a course anywhere. Lessons mix readings with
      quizzes, every chapter ends with a test, and your scores are tracked locally so you can
      see how you're doing at a glance.
    </p>
    <ul class="muted points">
      <li>No account and no server — enroll in a course and it's copied into this browser.</li>
      <li>Your progress, quiz answers, and test scores are saved locally and survive reloads.</li>
      <li>After the first visit, everything works fully offline.</li>
    </ul>
  </section>

  <HomeApp client:only="svelte" />
</Layout>

<style>
  .intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 65ch;
    margin-bottom: var(--space-6);
  }

  .tagline {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-primary-strong);
  }

  .points {
    padding-left: var(--space-5);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
</style>
