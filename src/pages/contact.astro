---
// General feedback page — only linked from the navbar when a contactEndpoint
// is configured in astro.config.mjs, but always built (the island explains
// itself when the feature is off).
import Layout from '../layouts/Layout.astro';
import ContactApp from '../components/contact/ContactApp.svelte';
---

<Layout title="Contact">
  <div class="page-header">
    <h1>Contact</h1>
  </div>
  <ContactApp client:only="svelte" />
</Layout>
