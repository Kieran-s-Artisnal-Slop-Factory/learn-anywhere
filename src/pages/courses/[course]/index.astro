---
// Course overview — statically rendered description + chapter list; the
// island handles enrollment (bundle copy into IndexedDB) and progress.
import { render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import CourseOverviewApp from '../../../components/course/CourseOverviewApp.svelte';
import { loadCourseTrees, toBundle } from '../../../lib/content/bundle';

export async function getStaticPaths() {
  const trees = await loadCourseTrees();
  return trees.map((tree) => ({ params: { course: tree.course.id }, props: { tree } }));
}

const { tree } = Astro.props;
const bundle = toBundle(tree);
const { Content } = await render(tree.course);
---

<Layout title={tree.course.data.title}>
  <nav class="breadcrumbs">
    <a href="/courses/">Courses</a>
  </nav>
  <div class="page-header">
    <h1>{tree.course.data.title}</h1>
  </div>
  <div class="prose">
    <Content />
  </div>
  <CourseOverviewApp client:only="svelte" {bundle} />
</Layout>

<style>
  .breadcrumbs {
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-2);
  }

  .prose {
    margin-bottom: var(--space-4);
    max-width: 65ch;
  }

  .prose :global(p) {
    margin-block: var(--space-3);
  }
</style>
