---
// Course page — the single navigation hub for a course: description,
// enroll / continue quick-access, and every chapter with its exercises.
// (Chapter overviews were folded in here; exercise pages link back to
// `#<chapter-slug>` anchors.)
import { render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import CourseOverviewApp from '../../../components/course/CourseOverviewApp.svelte';
import { loadCourseTrees, toBundle } from '../../../lib/content/bundle';

export async function getStaticPaths() {
  const trees = await loadCourseTrees();
  return trees.map((tree) => ({ params: { course: tree.course.id }, props: { tree } }));
}

const { tree } = Astro.props;
const bundle = toBundle(tree);
const { Content } = await render(tree.course);
const exerciseCount = bundle.exercises.length;
---

<Layout title={tree.course.data.title}>
  <nav class="breadcrumbs">
    <a href="/courses/">courses</a> / {tree.course.id}
  </nav>
  <div class="page-header">
    <h1>{tree.course.data.title}</h1>
    <span class="muted">{bundle.chapters.length} chapters · {exerciseCount} exercises</span>
  </div>
  <div class="prose description">
    <Content />
  </div>
  <CourseOverviewApp client:only="svelte" {bundle} />
</Layout>

<style>
  .description {
    margin-bottom: var(--space-5);
  }
</style>
