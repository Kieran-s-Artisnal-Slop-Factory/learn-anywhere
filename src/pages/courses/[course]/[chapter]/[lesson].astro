---
// Lesson page — statically rendered content beside the interactive island
// (the quiz for exercises, "Mark as read" for readings), with prev/next
// spanning the whole course. URL params are the leaf segments of the
// path-scoped ids, so URLs stay /courses/<course>/<chapter>/<lesson>/.
import { render } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import LessonApp from '../../../../components/exercise/LessonApp.svelte';
import FeedbackButton from '../../../../components/contact/FeedbackButton.svelte';
import {
  chapterContent,
  courseContent,
  lessonContent,
  loadCourseTrees,
} from '../../../../lib/content/bundle';
import { href } from '../../../../lib/paths';

export async function getStaticPaths() {
  const trees = await loadCourseTrees();
  return trees.flatMap((tree) => {
    // Flatten the course into one ordered list so prev/next walks across
    // chapter boundaries.
    const flat = tree.chapters.flatMap(({ chapter, lessons }) =>
      lessons.map((lesson) => ({ chapter, lesson }))
    );
    return flat.map(({ chapter, lesson }, i) => ({
      params: {
        course: tree.course.id,
        chapter: chapter.id.split('/').pop()!,
        lesson: lesson.id.split('/').pop()!,
      },
      props: {
        course: tree.course,
        chapter,
        lesson,
        prev: flat[i - 1] ?? null,
        next: flat[i + 1] ?? null,
        // The last lesson of a chapter with a test (any variant) points to it.
        chapterTestNext:
          (chapter.data.test !== undefined ||
            chapter.data.test_database !== undefined ||
            chapter.data.test_web !== undefined) &&
          chapter.data.lessons[chapter.data.lessons.length - 1] === lesson.id.split('/').pop(),
        position: {
          index: chapter.data.lessons.findIndex((leaf) => `${chapter.id}/${leaf}` === lesson.id) + 1,
          total: chapter.data.lessons.length,
        },
      },
    }));
  });
}

const { course, chapter, lesson, prev, next, chapterTestNext, position } = Astro.props;
const { Content } = await render(lesson);
// Any assessment block gets the two-column workspace layout.
const hasWorkspace =
  lesson.data.quiz !== undefined ||
  lesson.data.database !== undefined ||
  lesson.data.web !== undefined;
const kindLabel = lesson.data.quiz
  ? 'Exercise'
  : lesson.data.database
    ? 'Database exercise'
    : lesson.data.web
      ? 'Web exercise'
      : 'Reading';
const courseHref = href(`/courses/${course.id}/`);
const chapterHref = href(`/courses/${chapter.id}/`);
const coursePayload = courseContent(course);
const chapterPayload = await chapterContent(chapter);
const lessonPayload = await lessonContent(lesson);
---

<Layout title={lesson.data.title}>
  <nav class="breadcrumbs">
    <a href={href('/courses/')}>Courses</a> /
    <a href={courseHref}>{course.data.title}</a> /
    <a href={chapterHref}>{chapter.data.title}</a>
  </nav>
  <div class="page-header">
    <h1>{lesson.data.title}</h1>
    <span class="muted">
      {kindLabel} · Lesson {position.index} of {position.total} · {chapter.data.title}
    </span>
  </div>

  {
    hasWorkspace && (
      <div class="collapse-row">
        <button type="button" class="btn btn-sm" id="collapse-content" aria-expanded="true">
          Hide lesson content
        </button>
      </div>
    )
  }

  <div class="lesson-layout" class:list={[{ 'prose-only': !hasWorkspace }]}>
    <div class="instructions">
      <div class="prose">
        <Content />
      </div>
    </div>

    <div class="workspace">
      <LessonApp
        client:only="svelte"
        course={coursePayload}
        chapter={chapterPayload}
        lesson={lessonPayload}
      />
    </div>
  </div>

  <nav class="pager">
    {
      prev ? (
        <a class="btn" href={href(`/courses/${prev.lesson.id}/`)}>
          ← {prev.lesson.data.title}
        </a>
      ) : (
        <a class="btn" href={courseHref}>
          ← {course.data.title}
        </a>
      )
    }
    {
      chapterTestNext ? (
        <a class="btn" href={href(`/courses/${chapter.id}/test/`)}>
          Chapter test →
        </a>
      ) : next ? (
        <a class="btn" href={href(`/courses/${next.lesson.id}/`)}>
          {next.lesson.data.title} →
        </a>
      ) : (
        <a class="btn" href={courseHref}>
          Back to course →
        </a>
      )
    }
  </nav>

  <FeedbackButton client:only="svelte" title={lesson.data.title} />

  <script is:inline>
    // Collapse the lesson prose so the quiz/editor gets the full width.
    // Choice is remembered across lessons (localStorage), applied pre-paint.
    (() => {
      const KEY = 'learn-anywhere-collapse-lesson-content';
      const button = document.getElementById('collapse-content');
      const layout = document.querySelector('.lesson-layout');
      if (!button || !layout) return;
      const apply = (collapsed) => {
        layout.classList.toggle('content-collapsed', collapsed);
        button.textContent = collapsed ? 'Show lesson content' : 'Hide lesson content';
        button.setAttribute('aria-expanded', String(!collapsed));
      };
      apply(localStorage.getItem(KEY) === '1');
      button.addEventListener('click', () => {
        const collapsed = !layout.classList.contains('content-collapsed');
        try {
          localStorage.setItem(KEY, collapsed ? '1' : '0');
        } catch {}
        apply(collapsed);
      });
    })();
  </script>
</Layout>

<style>
  .collapse-row {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--space-3);
  }

  .lesson-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-5);
    align-items: start;
  }

  /* Collapsed: hide the prose, let the workspace take the full width. */
  .lesson-layout.content-collapsed .instructions {
    display: none;
  }

  @media (min-width: 64rem) {
    .lesson-layout:not(.prose-only):not(.content-collapsed) {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    }

    .lesson-layout:not(.prose-only) .instructions {
      position: sticky;
      top: calc(var(--navbar-height) + var(--space-4));
      max-height: calc(100dvh - var(--navbar-height) - var(--space-6));
      overflow-y: auto;
      padding-right: var(--space-3);
    }
  }

  .pager {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-5);
    flex-wrap: wrap;
  }
</style>
