---
// Exercise page — statically rendered instructions beside the interactive
// editor + engine island, with prev/next spanning the whole course (chapter
// boundaries included) since chapters no longer have their own pages.
import { render } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import ExerciseApp from '../../../../components/exercise/ExerciseApp.svelte';
import {
  chapterContent,
  courseContent,
  exerciseContent,
  loadCourseTrees,
} from '../../../../lib/content/bundle';

export async function getStaticPaths() {
  const trees = await loadCourseTrees();
  return trees.flatMap((tree) => {
    // Flatten the course into one ordered list so prev/next walks across
    // chapter boundaries.
    const flat = tree.chapters.flatMap(({ chapter, exercises }) =>
      exercises.map((exercise) => ({ chapter, exercise }))
    );
    return flat.map(({ chapter, exercise }, i) => ({
      params: { course: tree.course.id, chapter: chapter.id, exercise: exercise.id },
      props: {
        course: tree.course,
        chapter,
        exercise,
        prev: flat[i - 1] ?? null,
        next: flat[i + 1] ?? null,
        position: {
          index: chapter.data.exercises.findIndex((ref) => ref.id === exercise.id) + 1,
          total: chapter.data.exercises.length,
        },
      },
    }));
  });
}

const { course, chapter, exercise, prev, next, position } = Astro.props;
const { Content } = await render(exercise);
const courseHref = `/courses/${course.id}/`;
const exerciseHref = (e: { chapter: { id: string }; exercise: { id: string } }) =>
  `${courseHref}${e.chapter.id}/${e.exercise.id}/`;
---

<Layout title={exercise.data.title}>
  <nav class="breadcrumbs">
    <a href="/courses/">courses</a> /
    <a href={courseHref}>{course.data.title}</a> /
    <a href={`${courseHref}#${chapter.id}`}>{chapter.data.title}</a>
  </nav>
  <div class="page-header">
    <h1>{exercise.data.title}</h1>
    <span class="muted">exercise {position.index}/{position.total} · {chapter.data.title}</span>
  </div>

  <div class="exercise-layout">
    <div class="instructions">
      <div class="prose">
        <Content />
      </div>
    </div>

    <div class="workspace">
      <ExerciseApp
        client:only="svelte"
        course={courseContent(course)}
        chapter={chapterContent(chapter)}
        exercise={exerciseContent(exercise)}
      />
    </div>
  </div>

  <nav class="pager">
    {
      prev ? (
        <a class="btn" href={exerciseHref(prev)}>
          ← {prev.exercise.data.title}
        </a>
      ) : (
        <a class="btn" href={courseHref}>
          ← {course.data.title}
        </a>
      )
    }
    {
      next ? (
        <a class="btn" href={exerciseHref(next)}>
          {next.exercise.data.title} →
        </a>
      ) : (
        <a class="btn" href={courseHref}>
          Back to course →
        </a>
      )
    }
  </nav>
</Layout>

<style>
  .exercise-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--space-5);
    align-items: start;
  }

  @media (min-width: 64rem) {
    .exercise-layout {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    }

    .instructions {
      position: sticky;
      top: calc(var(--navbar-height) + var(--space-4));
      max-height: calc(100dvh - var(--navbar-height) - var(--space-6));
      overflow-y: auto;
      padding-right: var(--space-3);
    }
  }

  .pager {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    margin-top: var(--space-5);
    flex-wrap: wrap;
  }
</style>
