---
import '../styles/theme.css';
import '../styles/global.css';
import { href } from '../lib/paths';
import Navbar from '../components/Navbar.svelte';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const swPath = href('/sw.js');
const onboardingPath = href('/onboarding/');
---

<!doctype html>
<html lang="en" data-sw-path={swPath} data-onboarding-path={onboardingPath}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content="lite-learner — local-first app" />
    <link rel="icon" href={href('/favicon.svg')} type="image/svg+xml" />
    <link rel="manifest" href={href('/manifest.webmanifest')} />
    <link rel="apple-touch-icon" href={href('/icons/icon-192.png')} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fbf1c7" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#282828" />
    <title>{title} · lite-learner</title>
    <script is:inline>
      // Apply the manual theme override before first paint to avoid a flash.
      // 'light'/'dark' pin the scheme; anything else follows the OS setting.
      // data-theme lets CSS that can't use light-dark() (e.g. Shiki's dual
      // highlight variables) follow the same pin.
      try {
        const theme = localStorage.getItem('lite-learner-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.style.colorScheme = theme;
          document.documentElement.dataset.theme = theme;
        }
        const palette = localStorage.getItem('lite-learner-palette');
        if (palette === 'boring' || palette === 'forrest') {
          document.documentElement.dataset.palette = palette;
        }
      } catch {}
    </script>
    <script is:inline define:vars={{ onboardingPath }}>
      // First-run gate: send new users through onboarding once (MPA — runs on
      // every page). Storage failures fall through to the app rather than
      // trapping the user in a redirect loop.
      try {
        if (
          (!location.pathname.endsWith('/onboarding/') && !location.pathname.endsWith('/onboarding')) &&
          !localStorage.getItem('lite-learner-onboarded')
        ) {
          location.replace(onboardingPath);
        }
      } catch {}
    </script>
  </head>
  <body>
    <Navbar client:load {currentPath} />
    <main class="page">
      <slot />
    </main>
    {
      import.meta.env.PROD ? (
        <script is:inline>
          if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
              navigator.serviceWorker.register(document.documentElement.dataset.swPath).catch(() => {});
            });
          }
        </script>
      ) : (
        <script is:inline>
          // Dev: the service worker must NOT run — it caches Vite's module
          // URLs and serves stale code after edits (blank pages). Unregister
          // any leftover registration and drop its caches.
          if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then((regs) => {
              for (const reg of regs) reg.unregister();
            });
            if (window.caches) {
              caches.keys().then((keys) => keys.forEach((k) => caches.delete(k)));
            }
          }
        </script>
      )
    }
  </body>
</html>
